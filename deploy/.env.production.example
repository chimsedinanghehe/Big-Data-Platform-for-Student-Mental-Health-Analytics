# Public endpoint. Replace only these values when domain/host is ready.
APP_DOMAIN=mental-health.example.com
ACME_EMAIL=admin@example.com

# PostgreSQL. Generate a strong URL-safe password (letters, digits, - and _).
POSTGRES_DB=student_mental_health_app
POSTGRES_USER=student_app
POSTGRES_PASSWORD=replace-with-strong-random-password
DATABASE_CONNECT_TIMEOUT_SECONDS=10

# Application secrets and external services.
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-5.4-mini
QDRANT_URL=http://replace-with-qdrant-host:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=student_mental_health
QDRANT_VECTOR_SIZE=384
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Optional. Leave empty unless the model artifact is provisioned inside Backend.
RAG_EMOTION_MODEL_PATH=
DEBUG_RAG=false

# Google Cloud. Mount a service-account JSON or temporary authorized-user ADC
# at deploy/secrets/gcp-service-account.json for production.
GCP_PROJECT_ID=student-mental-health-496205
GCP_REGION=asia-southeast1
GCS_BUCKET_NAME=student-mental-health-lake-nhom1-2026
GCS_BUCKET=student-mental-health-lake-nhom1-2026
GCS_KNOWLEDGE_BASE_PREFIX=bronze/knowledge_base
GCS_CHATLOG_PREFIX=bronze/chat_logs

# Big Data integration. Keep false until both production secrets are installed.
BIGDATA_ENABLED=false
READINESS_REQUIRE_GCS=false
READINESS_REQUIRE_KAFKA=false
SURVEY_SNAPSHOT_BATCH_LIMIT=100
SURVEY_SNAPSHOT_POLL_SECONDS=60

# Kafka VM SSH tunnel. The public Kafka broker port stays closed.
KAFKA_SSH_HOST=34.21.211.62
KAFKA_SSH_USER=Admin
KAFKA_SSH_PORT=22
KAFKA_LOCAL_PORT=9092
KAFKA_REMOTE_HOST=127.0.0.1
KAFKA_REMOTE_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
CHAT_KAFKA_ENABLED=false
CHAT_KAFKA_TOPIC=student-chat-logs
SURVEY_KAFKA_ENABLED=false
SURVEY_KAFKA_TOPIC=student-survey-events
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Cloud Workflow and Scheduler for Dataproc Serverless Spark.
GCP_WORKFLOW_NAME=nightly-dashboard-refresh
GCP_WORKFLOW_SERVICE_ACCOUNT=dashboard-refresh@student-mental-health-496205.iam.gserviceaccount.com
GCP_SCHEDULER_NAME=nightly-dashboard-refresh-0230-vn
GCP_SCHEDULER_CRON=30 2 * * *
GCP_SCHEDULER_TIMEZONE=Asia/Ho_Chi_Minh

# Optional image pinning/version label.
APP_VERSION=latest
