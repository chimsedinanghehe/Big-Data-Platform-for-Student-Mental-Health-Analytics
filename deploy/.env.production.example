# Public endpoint. Replace only these values when domain/host is ready.
APP_DOMAIN=mental-health.example.com
ACME_EMAIL=admin@example.com

# PostgreSQL. Generate a strong URL-safe password (letters, digits, - and _).
POSTGRES_DB=student_mental_health_app
POSTGRES_USER=student_app
POSTGRES_PASSWORD=replace-with-strong-random-password
DATABASE_CONNECT_TIMEOUT_SECONDS=10

# Application secrets and external services.
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-5.4-mini
QDRANT_URL=http://replace-with-qdrant-host:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=student_mental_health
QDRANT_VECTOR_SIZE=384
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Optional. Leave empty unless the model artifact is provisioned inside Backend.
RAG_EMOTION_MODEL_PATH=
DEBUG_RAG=false

# Google Cloud. Mount deploy/secrets/gcp-service-account.json for production.
GCP_PROJECT_ID=student-mental-health-496205
GCS_BUCKET_NAME=student-mental-health-lake-nhom1-2026
GCS_BUCKET=student-mental-health-lake-nhom1-2026
GCS_KNOWLEDGE_BASE_PREFIX=bronze/knowledge_base
GCS_CHATLOG_PREFIX=bronze/chat_logs

# Kafka endpoint reachable from the deployment host.
# Do not use 127.0.0.1 unless Kafka runs on the same host.
KAFKA_BOOTSTRAP_SERVERS=replace-with-private-kafka-endpoint:9092
CHAT_KAFKA_TOPIC=student-chat-logs
SURVEY_KAFKA_ENABLED=false
SURVEY_KAFKA_TOPIC=student-survey-events
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Optional image pinning/version label.
APP_VERSION=latest
